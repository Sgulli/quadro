{
  "name": "@qquadro/core",
  "version": "0.4.1",
  "description": "Fluent, fully-typed Excel builder for Node.js — styles, formulas, merged cells, headers, streaming",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:js && npm run build:dts",
    "build:js": "rolldown -c",
    "build:dts": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.cjs.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "excel",
    "xlsx",
    "excelts",
    "typescript",
    "builder",
    "spreadsheet",
    "workbook"
  ],
  "license": "MIT",
  "author": "Sgulli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sgulli/quadro.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Sgulli/quadro/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Sgulli/quadro/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@cj-tech-master/excelts": "9.5.7"
  },
  "devDependencies": {
    "@quadro/tsconfig": "workspace:*",
    "rolldown": "^1.0.2",
    "typescript": "^5.8.3",
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7"
  }
}
