    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@quadro/core": "workspace:*",
    "citty": "^0.1.6",
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@quadro/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  }
}
