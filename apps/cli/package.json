{
  "name": "@quadro/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "quadro": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
